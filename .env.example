# 设置时区
TZ=Asia/Shanghai

# 设置网络模式
NETWORKS_DRIVER=bridge

# PATHS ##########################################
# 宿主机上 Mysql/Reids 数据存放的目录路径
DATA_PATH_HOST=./storage

# nginx, 此端口应该与 nginx/host.conf 中保持一致
OPEN_PORT=8071
# ./src 保存项目源码，会被挂载到 /var/www

# postgres
# https://hub.docker.com/_/postgres
# 原 5432 端口被占用, 在 pgadmin 中连接时，使用的连接信息为 postgres:5432
POSTGRES_PORT=5454
# 以下配置信息与 postgres/Dockerfile 配置相同
POSTGRES_USER=admin
POSTGRES_PASSWORD=123456
POSTGRES_DB=admin

# mysql
MYSQL_HOST=mysql
MYSQL_PORT=5455
MYSQL_ROOT_PASSWORD=root123
MYSQL_PASSWORD=123456
MYSQL_USER=admin
MYSQL_DATABASE=phalcon

# phpmyadmin 端口
PHPMYADMIN_PORT=5456

# REDIS ##########################################
# Redis 服务映射宿主机端口号，可在宿主机 127.0.0.1:6379 访问
REDIS_PORT=5457
# redis 连接密码
REDIS_PASSWORD=12

# memcached 服务端口
MEMCACHED_PORT=5458

# 当前 PHP 应用名称，影响 src/config 目录下加载的配置文件，与 docker-compose 无关
# 推荐只在线上时设置
APP_PROJECT=