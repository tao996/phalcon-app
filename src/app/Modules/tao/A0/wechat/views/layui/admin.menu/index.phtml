<?php $layui->footer(); ?>
<?php $layui->addWindowConfig([]); ?>
<script>
    const prefix = '<?php echo url("tao.wechat/admin.menu") ?>';
    const kind = <?php echo json_encode(\app\Modules\tao\A0\wechat\Models\WechatApp::MapKinds)?>;
    admin.table.with({url: prefix, key: 'app_id'})
        .render({
            toolbar: '#toolbar',
            cols: [[
                {
                    field: 'kind', title: '类型', width: 150, templet: function (d) {
                        return kind[d.kind];
                    }
                },
                {field: 'sync', title: '启用同步', width: 120, templet: admin.table.switch},
                {field: 'sync_at', title: '最近同步', width: 120, templet: admin.table.humanTime},
                {field: 'app_id', title: 'AppId', width: 200},
                {field: 'title', title: '名称', width: 200},
                {
                    title: '操作', toolbar: '#row-action',
                }
            ]],
        })
        .addPostSwitch(['sync'])
        .addLayOnActions()
        .addLayEventActions({
            events: function (obj) {
                admin.iframe.open(prefix + '/edit?app_id=' + obj.data.app_id, {
                    title: '公众号菜单设置',
                })
            }
        });

</script>
